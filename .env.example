# ============================================================
# .env.example - 환경 설정 파일 템플릿
#
# [사용 방법]
# 이 파일을 복사해서 파일명을 ".env" 로 변경한 후
# 아래 값들을 실제 환경에 맞게 수정하세요.
#
# [주의사항]
# - 파일명: .env  (점으로 시작, 확장자 없음)
# - 위치: main.py 와 같은 폴더 안에 있어야 합니다.
# - 이 파일(.env)은 절대 외부에 공유하지 마세요. (토큰 노출 위험)
# ============================================================

# kdb_mw 서버 주소
# 예시: http://192.168.1.100:8000  또는  http://kdbmw.intranet:8000
KDB_BASE_URL=http://kdb_mw서버주소:포트번호

# JWT 인증 토큰 (365일 유효)
# 발급 방법: 브라우저에서 kdb_mw에 로그인 후
#            http://kdb_mw서버주소/common/generate_long_term_token 접속
KDB_TOKEN=여기에_발급받은_토큰_붙여넣기

# SSL 인증서 검증 여부
# false = 검증 안 함 (사내 사설 인증서 환경에서 주로 사용)
# true  = 검증함    (공인 인증서 환경)
VERIFY_SSL=false
